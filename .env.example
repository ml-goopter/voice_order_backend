```dotenv
# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Redis
REDIS_URL=redis://localhost:6379
CART_IDEMPOTENCY_TTL_SECONDS=86400
DEVICE_INDEX_TTL_SECONDS=86400

# Postgres / pgvector
# Used for menu reads and the item_vector table. Cart state remains in Redis.
ODOO_DATABASE_URL=postgres://localhost:5432/odoo

# Odoo API
# Used to insert confirmed carts through the goopter_cart_api addon.
ODOO_API_URL=http://localhost:8069
ODOO_API_DATABASE=jadegarden1
# ODOO_API_KEY=

# Speech-to-text
STT_PROVIDER=assemblyai
STT_SAMPLE_RATE=16000
# ASSEMBLYAI_API_KEY=

# Main LLM
# Supported providers: stub, ollama, openai
LLM_PROVIDER=stub
LLM_MODEL=llama3.1
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
# LLM_TIMEOUT_MS=30000

# Intent classifier
# Defaults to the matching LLM_* values when unset.
INTENT_LLM_PROVIDER=openai
INTENT_LLM_MODEL=gpt-4o-mini
INTENT_LLM_BASE_URL=https://api.openai.com/v1
# INTENT_LLM_API_KEY=sk-...
# INTENT_LLM_TIMEOUT_MS=30000

# Text-to-speech
# Supported providers: cartesia, noop
TTS_PROVIDER=cartesia
TTS_MODEL=sonic-3.5
TTS_VOICE_ID=694f9389-aac1-45b6-b726-9d9369183238
TTS_LANGUAGE=en
TTS_ENCODING=mp3
TTS_SAMPLE_RATE=24000
TTS_BIT_RATE=128000
# CARTESIA_API_KEY=

# Menu filtering
# Comma-separated POS categories excluded during menu seeding.
# MENU_EXCLUDED_CATEGORIES=CUSTOMER TYPE

# Embeddings
# Supported providers: stub, jina
EMBEDDING_PROVIDER=stub
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSIONS=1024
# JINA_API_KEY=
# JINA_BASE_URL=https://api.jina.ai/v1/embeddings
```
