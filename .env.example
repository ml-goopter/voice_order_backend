# Copy to .env and fill in. All have safe defaults for local scaffold boot.
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://localhost:5432/voice_ordering

# Providers (design §14)
STT_PROVIDER=assemblyai
LLM_PROVIDER=groq
EMBEDDING_MODEL=text-embedding-3-small

# Provider keys (add when wiring real clients)
# ASSEMBLYAI_API_KEY=
# DEEPGRAM_API_KEY=
# GROQ_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
