# Copy to .env and fill in. All have safe defaults for local scaffold boot.
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Infrastructure
REDIS_URL=redis://localhost:6379
# Postgres (Odoo POS DB) — also holds our `item_vector` table (pgvector). The menu
# backend is Postgres/pgvector; cart state stays on Redis.
ODOO_DATABASE_URL=postgres://localhost:5432/odoo
# TTL (seconds) on the cart idempotency ledger; keeps it bounded. Default 86400 (24h).
CART_IDEMPOTENCY_TTL_SECONDS=86400
# TTL (seconds) on the device:{id} / table:{id} cart traceability indexes. Refreshed on
# every cart write, so an idle device's order history expires as a whole. Default 86400 (24h).
DEVICE_INDEX_TTL_SECONDS=86400

# Odoo JSON-RPC API (the goopter_cart_api addon) — where confirmed carts are inserted.
# UNRELATED to ODOO_DATABASE_URL above, which is the Postgres/pgvector menu read path.
ODOO_API_URL=http://localhost:8069
# Odoo database name, sent as the X-Odoo-Database header. REQUIRED when the instance serves
# several databases and has no dbfilter — it cannot pick one itself and answers an HTML 404
# ("No database is selected") no matter how good the API key is. Leave empty for a
# single-database instance, or one whose dbfilter already resolves to exactly one.
ODOO_API_DATABASE=jadegarden1
# API key of the integration user. That user must be an internal user AND a POS user —
# group_pos_user alone cannot read product.template.attribute.value. Odoo 19 requires
# every API key to carry an expiration date, so this needs rotating before it lapses.
# ODOO_API_KEY=

# Providers (design §14)
STT_PROVIDER=assemblyai

# LLM — any OpenAI-compatible endpoint via the OpenAI SDK (see llm/openai-compatible-provider.ts).
LLM_PROVIDER=stub                # 'stub' | 'ollama' | 'openai'
LLM_MODEL=llama3.1               # e.g. llama3.1 (Ollama) | gpt-4o-mini (OpenAI)
LLM_BASE_URL=http://localhost:11434/v1   # Ollama default; https://api.openai.com/v1 for OpenAI
LLM_API_KEY=ollama               # any non-empty value for Ollama; real key for OpenAI
# Intent classifier LLM (design §6, cheap first-hop call). Each INTENT_LLM_* falls back to the
# matching LLM_* above — set them only to run the classifier on a separate provider/model/key.
# INTENT_LLM_PROVIDER=openai       # defaults to LLM_PROVIDER
# INTENT_LLM_MODEL=gpt-4o-mini     # defaults to LLM_MODEL; a cheap model is plenty for routing
# INTENT_LLM_BASE_URL=https://api.openai.com/v1  # defaults to LLM_BASE_URL
# INTENT_LLM_API_KEY=sk-...        # defaults to LLM_API_KEY
# INTENT_LLM_TIMEOUT_MS=30000      # defaults to LLM_TIMEOUT_MS
# Providers (design §14) — swap the cloud STT provider via STT_PROVIDER only.
STT_PROVIDER=assemblyai          # 'assemblyai' | 'noop'
STT_SAMPLE_RATE=16000            # Hz of the client PCM16 mono stream
# ASSEMBLYAI_API_KEY=            # required when STT_PROVIDER=assemblyai (else falls back to noop)

# Text-to-speech — the agent's spoken replies (order.reply) are synthesized and streamed to the
# client as base64 tts.audio_chunk frames. Cartesia Sonic; swap the provider via TTS_PROVIDER only.
TTS_PROVIDER=cartesia            # 'cartesia' | 'noop'
TTS_MODEL=sonic-3.5              # Cartesia Sonic model (sonic-3.5 = multilingual, 42 languages)
TTS_VOICE_ID=694f9389-aac1-45b6-b726-9d9369183238  # Cartesia voice UUID — pick a multi-locale voice
TTS_LANGUAGE=en                  # ISO-639-1 fallback when the customer's turn detected no language
TTS_ENCODING=mp3                 # 'mp3' (easy client playback) | 'linear16'
TTS_SAMPLE_RATE=24000            # Hz of the emitted audio (also required by the mp3 container)
TTS_BIT_RATE=128000              # mp3 bit rate (bps) for the Cartesia mp3 container
# CARTESIA_API_KEY=             # required when TTS_PROVIDER=cartesia (else falls back to noop)


# Menu — POS category names whose products are not dishes (cover charges, the negative-price
# Discount product). Comma-separated, matched against the POS category name as it appears in the
# POS UI. The seed skips their products, so they never enter `item_vector` and are neither
# searchable nor recommendable. Per-tenant and empty by default: Izumi needs "CUSTOMER TYPE"
# (without it its "Adult" cover charge is the #2 seller and leads "what do you suggest?"); Jade
# Garden needs nothing. Applied at SEED time — changing it requires a reseed (npm run seed:menu:pg).
# MENU_EXCLUDED_CATEGORIES=CUSTOMER TYPE

# Embeddings — swap models/providers via env only (see menu/embedding-service.ts).
EMBEDDING_PROVIDER=stub          # 'stub' | 'jina'
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSIONS=1024
# JINA_API_KEY=                   # required when EMBEDDING_PROVIDER=jina
# JINA_BASE_URL=https://api.jina.ai/v1/embeddings
