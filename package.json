{
  "name": "voice_based_ordering",
  "version": "0.1.0",
  "description": "Voice-based restaurant ordering — event-driven modular monolith (see design.cleaned.md)",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "test": "vitest run",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "seed:menu:pg": "tsx --env-file-if-exists=.env scripts/populate-postgres-menu.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@cartesia/cartesia-js": "^3.3.0",
    "@langchain/langgraph": "^1.4.7",
    "assemblyai": "^4.35.3",
    "ioredis": "^5.11.1",
    "openai": "^6.45.0",
    "pg": "^8.22.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  }
}
